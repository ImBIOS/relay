{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Relay Patch Registry",
  "description": "Registry of all Relay Patches applied to this fork. Used by the fork-sync workflow to track and re-apply patches.",
  "type": "object",
  "required": ["patches"],
  "properties": {
    "patches": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "name", "status", "createdAt", "updatedAt"],
        "properties": {
          "id": {
            "type": "string",
            "description": "Unique identifier (slug)"
          },
          "name": {
            "type": "string",
            "description": "Human-readable patch name"
          },
          "status": {
            "type": "string",
            "enum": ["active", "superseded", "removed"],
            "description": "Current patch status"
          },
          "createdAt": {
            "type": "string",
            "format": "date-time"
          },
          "updatedAt": {
            "type": "string",
            "format": "date-time"
          },
          "appliesTo": {
            "type": "string",
            "description": "Upstream version or commit this patch was last verified against"
          },
          "upstreamIssue": {
            "type": "string",
            "description": "URL of the upstream issue tracking this feature request"
          },
          "files": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["path", "changeType"],
              "properties": {
                "path": {
                  "type": "string"
                },
                "changeType": {
                  "type": "string",
                  "enum": ["modify", "add", "delete"]
                }
              }
            }
          }
        }
      }
    }
  }
}
