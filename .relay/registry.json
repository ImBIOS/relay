{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/ImBIOS/relay/.relay/registry.json",
  "title": "Relay Feature Registry",
  "description": "Master registry of all features in the Relay project. Each feature has a folder in .relay/features/.",
  "type": "object",
  "properties": {
    "features": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "slug", "title", "status"],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^\\d{3,}$",
            "description": "Numeric ID matching the folder prefix (e.g., '001')"
          },
          "slug": {
            "type": "string",
            "pattern": "^[a-z0-9-]+$",
            "description": "URL-friendly slug matching the folder name suffix (e.g., 'proxy')"
          },
          "title": {
            "type": "string",
            "description": "Human-readable feature title"
          },
          "status": {
            "type": "string",
            "enum": ["proposed", "in-progress", "implemented", "deprecated", "removed"],
            "description": "Current feature status"
          },
          "hasPatch": {
            "type": "boolean",
            "default": false,
            "description": "Whether this feature has a patch.md (fork customization)"
          },
          "upstreamIssue": {
            "type": "string",
            "description": "URL of the upstream issue for this patch (if applicable)"
          },
          "upstreamPR": {
            "type": "string",
            "description": "URL of the upstream PR for this patch (if applicable)"
          },
          "lastUpdated": {
            "type": "string",
            "format": "date-time",
            "description": "ISO 8601 timestamp of last update"
          }
        }
      }
    }
  },
  "required": ["features"],
  "features": [
    {
      "id": "000",
      "slug": "init-relay",
      "title": "Initialize Relay Directory",
      "status": "implemented",
      "hasPatch": false,
      "lastUpdated": "2026-04-25T00:00:00Z"
    },
    {
      "id": "001",
      "slug": "proxy",
      "title": "Relay Proxy Server",
      "status": "implemented",
      "hasPatch": false,
      "lastUpdated": "2026-04-25T00:00:00Z"
    }
  ]
}
