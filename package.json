{
  "name": "relay",
  "version": "2.1.0",
  "description": "CLI for managing AI API providers — switch, rotate, track usage across Z.AI, MiniMax, and more",
  "keywords": [
    "anthropic",
    "api",
    "claude-code",
    "cli",
    "glm",
    "minimax",
    "opencode",
    "provider",
    "proxy",
    "rotation"
  ],
  "author": {
    "name": "Imamuzzaki Abu Salam",
    "email": "imamuzzaki@gmail.com",
    "url": "https://github.com/ImBIOS"
  },
  "bin": {
    "relay": "./src/run.ts"
  },
  "workspaces": [
    "packages/*"
  ],
  "type": "module",
  "exports": {
    ".": "./src/oclif/base.tsx",
    "./sdk": "./src/sdk/index.ts"
  },
  "scripts": {
    "build": "bun build src/cli.ts --outfile=bin/relay.bundled.js --target=node --packages=external",
    "dev": "bun --hot src/cli.ts",
    "test": "bun test",
    "test:coverage": "bun test --coverage",
    "test:watch": "bun test --watch",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.119",
    "@anthropic-ai/sdk": "^0.72.1",
    "@inkjs/ui": "^2.0.0",
    "@oclif/core": "^4.8.0",
    "ink": "^6.6.0",
    "jsonc": "^2.0.0",
    "react": "^19.2.5",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@happy-dom/global-registrator": "^20.5.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/bun": "^1.3.12",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.14"
  },
  "oclif": {
    "bin": "relay",
    "commands": {
      "glob": "**/*.tsx",
      "strategy": "pattern",
      "target": "./src/commands"
    },
    "default": "help",
    "dirname": "relay",
    "flexibleTaxonomy": true,
    "topicSeparator": " ",
    "topics": {
      "account": {
        "description": "Multi-account management"
      },
      "alert": {
        "description": "Alert configuration"
      },
      "auto": {
        "description": "Cross-provider auto-rotation"
      },
      "compare": {
        "description": "Side-by-side Claude comparison"
      },
      "dashboard": {
        "description": "Web dashboard management"
      },
      "mcp": {
        "description": "MCP server management"
      },
      "profile": {
        "description": "Manage configuration profiles"
      },
      "proxy": {
        "description": "Anthropic API proxy server for hot-switching providers"
      }
    }
  }
}
